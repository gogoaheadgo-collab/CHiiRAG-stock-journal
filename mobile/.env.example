# Copy this file to .env and fill in your values
# Expo requires the EXPO_PUBLIC_ prefix for client-side env vars

# Your Supabase project URL (same as NEXT_PUBLIC_SUPABASE_URL in your web app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon key (same as NEXT_PUBLIC_SUPABASE_ANON_KEY in your web app)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Your deployed Vercel URL — NO trailing slash
EXPO_PUBLIC_API_URL=https://smk-stock-journal.vercel.app
